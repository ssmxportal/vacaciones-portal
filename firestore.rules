rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // La app firma con Firebase Anonymous Auth al cargar (ver app.js).
    // En Firebase Console: Authentication → Sign-in method → Anonymous → Enable.
    // Sin esto, signInAnonymously falla y el saldo no persiste en la nube.

    match /operatorVacationSaldo/{operatorId} {
      allow read, write: if request.auth != null;
    }

    match /solicitudes/{folio} {
      allow read, write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
